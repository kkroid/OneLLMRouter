# ============================================================
# Provider 配置
# 格式：PROVIDER_<PREFIX>_<FIELD>
#   NAME     provider 名称
#   BASE_URL Anthropic-compatible API 地址（cp 无需）
#   API_KEY  API 密钥（cp 无需）
#   MODELS   可用模型（逗号分隔）
# ============================================================

# --- ds: DeepSeek ---
PROVIDER_DS_NAME=DeepSeek
PROVIDER_DS_BASE_URL=https://api.deepseek.com/anthropic
PROVIDER_DS_API_KEY=sk-your-deepseek-key
PROVIDER_DS_MODELS=deepseek-v4-pro,deepseek-v4-flash

# --- cp: GitHub Copilot ---
PROVIDER_CP_NAME=GitHub Copilot
PROVIDER_CP_API_KEY=not-needed
PROVIDER_CP_MODELS=claude-opus-4.8,claude-fable-5

# --- 添加新 provider：复制上面一组，换 PREFIX ---
# PROVIDER_MY_NAME=My API
# PROVIDER_MY_BASE_URL=https://my-api.example.com/anthropic
# PROVIDER_MY_API_KEY=sk-xxx
# PROVIDER_MY_MODELS=model-a,model-b

# ============================================================
# Claude Code 模型槽位（用于生成 out/claude-code-settings.json）
# 值 = <PREFIX>/<MODEL>，如 ds/deepseek-v4-pro
# ============================================================
ANTHROPIC_MODEL=ds/deepseek-v4-pro
ANTHROPIC_DEFAULT_FABLE_MODEL=cp/claude-fable-5
ANTHROPIC_DEFAULT_OPUS_MODEL=cp/claude-opus-4.8
ANTHROPIC_DEFAULT_SONNET_MODEL=ds/deepseek-v4-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=ds/deepseek-v4-flash
